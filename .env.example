OPENAI_API_KEY=sk-...

# Matches docker-compose.yml defaults — change for a remote or prod DB.
DATABASE_URL=postgresql://scorechat:scorechat@localhost:5432/scorechat

# Model providers — pick per pipeline/providers.py. Install the matching
# extra first, e.g. `uv pip install -e ".[anthropic]"` or ".[ollama]".
CHAT_PROVIDER=openai        # openai | anthropic | ollama
# CHAT_MODEL=claude-sonnet-5
EMBEDDING_PROVIDER=openai   # openai | ollama (Anthropic has no embeddings API)
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ANTHROPIC_API_KEY=sk-ant-...       # required if CHAT_PROVIDER=anthropic
# OLLAMA_BASE_URL=http://localhost:11434   # optional, for CHAT/EMBEDDING_PROVIDER=ollama
